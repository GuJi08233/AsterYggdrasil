{
	"name": "asteryggdrasil-panel",
	"private": true,
	"version": "0.1.0-alpha.5",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsgo -b && vite build",
		"generate-api": "openapi-typescript ./generated/openapi.json -o ./src/types/api.generated.ts",
		"check": "tsgo -b && biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:asteryggdrasil": "playwright test e2e",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@fontsource-variable/geist": "^5.2.9",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"axios": "^1.18.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^26.3.1",
		"papaparse": "^5.5.3",
		"react": "^19.2.7",
		"react-devicons": "^2.16.2",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8",
		"react-icons": "^5.6.0",
		"react-image-crop": "^11.0.10",
		"react-router-dom": "^7.18.0",
		"recharts": "^3.8.1",
		"skinview3d": "^3.4.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"xml-formatter": "^3.7.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@playwright/test": "^1.61.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.3",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260617.2",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.9",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"shadcn": "^4.11.0",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9"
	},
	"overrides": {
		"@babel/plugin-transform-modules-systemjs": "7.29.4",
		"@hono/node-server": "2.0.3",
		"brace-expansion": "5.0.6",
		"fast-uri": "3.1.2",
		"hono": "4.12.22",
		"ip-address": "10.2.0",
		"picomatch": "4.0.4",
		"react": "^19.2.7"
